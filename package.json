{
  "name": "box-balance",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host",
    "server": "node server/index.js",
    "dev:all": "concurrently -n web,ws -c cyan,magenta \"npm run dev\" \"npm run server\"",
    "dev:all:lan": "concurrently -n web,ws -c cyan,magenta \"npm run dev:lan\" \"npm run server\"",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "vite preview --host",
    "mobile": "npm --prefix mobile start",
    "mobile:android": "npm --prefix mobile run android"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "@react-three/rapier": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.3",
    "concurrently": "^9.1.0",
    "vite": "^5.4.10"
  }
}
